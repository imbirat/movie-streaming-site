# Strelix Stream Environment Variables
# Copy this file to `.env.local` and fill in your real keys.
# NEVER commit your real .env.local file.

# TMDB API Key (https://www.themoviedb.org/settings/api)
VITE_TMDB_API_KEY=your_tmdb_api_key_here

# Firebase Config (https://console.firebase.google.com/)
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=1234567890
VITE_FIREBASE_APP_ID=1:1234567890:web:abcdef123456

# Public URL (used for SEO + sitemap)
VITE_PUBLIC_URL=https://strelix.stream

# TMDB Image URLs (rarely need to change)
VITE_TMDB_IMAGE_BASE=https://image.tmdb.org/t/p
